# ── Data (tracked by DVC, not git) ───────────────────────────────
# Ignore actual data files but allow .dvc pointer files
data/raw/*.csv
data/raw/*.parquet
data/processed/
*.csv
!*.dvc

# ── Models ────────────────────────────────────────────────────────
# Allow the trained model and scaler — small enough to commit (~750 KB)
# and required for Docker image builds in CI/CD
models/*.pkl
!models/fraud_model.pkl
!models/scaler.pkl
models/*.joblib

# ── MLflow ────────────────────────────────────────────────────────
mlruns/
mlartifacts/

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ──────────────────────────────────────────
venv/
.venv/
env/

# ── Environment secrets ───────────────────────────────────────────
.env
*.pem
*.key
azure_credentials.json

# ── Logs ──────────────────────────────────────────────────────────
logs/*.log

# ── Jupyter ───────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
